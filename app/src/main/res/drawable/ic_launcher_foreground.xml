<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- The Ball Surface with 3D Radial Gradient -->
    <path android:pathData="M 54, 54 m -35, 0 a 35,35 0 1,1 70,0 a 35,35 0 1,1 -70,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="40"
                android:centerY="40"
                android:gradientRadius="50"
                android:type="radial">
                <item
                    android:color="#FFFFFF"
                    android:offset="0.0" />
                <item
                    android:color="@color/on_background"
                    android:offset="0.4" />
                <item
                    android:color="#000000"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Basketball Lines with 3D Gradients (Optimized length to match ball curvature) -->
    <group>
        <!-- Horizontal Line -->
        <path
            android:pathData="M 20.3, 54 L 87.7, 54"
            android:strokeWidth="2.5"
            android:strokeLineCap="round">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:startX="20.3"
                    android:startY="54"
                    android:endX="87.7"
                    android:endY="54"
                    android:type="linear">
                    <item android:color="#E0FFFFFF" android:offset="0.0" />
                    <item android:color="@color/primary" android:offset="0.4" />
                    <item android:color="#000000" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>
        <!-- Vertical Line -->
        <path
            android:pathData="M 54, 20.3 L 54, 87.7"
            android:strokeWidth="2.5"
            android:strokeLineCap="round">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:startX="54"
                    android:startY="20.3"
                    android:endX="54"
                    android:endY="87.7"
                    android:type="linear">
                    <item android:color="#E0FFFFFF" android:offset="0.0" />
                    <item android:color="@color/primary" android:offset="0.4" />
                    <item android:color="#000000" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>
        <!-- Left Curve -->
        <path
            android:pathData="M 30.1, 30.1 C 45, 45 45, 63 30.1, 77.9"
            android:strokeWidth="2.5"
            android:strokeLineCap="round"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:startX="45"
                    android:startY="30.1"
                    android:endX="30.1"
                    android:endY="77.9"
                    android:type="linear">
                    <item android:color="#E0FFFFFF" android:offset="0.0" />
                    <item android:color="@color/primary" android:offset="0.4" />
                    <item android:color="#000000" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>
        <!-- Right Curve -->
        <path
            android:pathData="M 77.9, 30.1 C 63, 45 63, 63 77.9, 77.9"
            android:strokeWidth="2.5"
            android:strokeLineCap="round"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:startX="63"
                    android:startY="30.1"
                    android:endX="77.9"
                    android:endY="77.9"
                    android:type="linear">
                    <item android:color="#E0FFFFFF" android:offset="0.0" />
                    <item android:color="@color/primary" android:offset="0.4" />
                    <item android:color="#000000" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>
    </group>

    <!-- Shiny Highlight for 3D effect -->
    <path
        android:pathData="M 45, 30 a 15,10 45 0,1 10,5"
        android:strokeWidth="4"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="45"
                android:startY="30"
                android:endX="55"
                android:endY="35"
                android:type="linear">
                <item android:color="#CCFFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>